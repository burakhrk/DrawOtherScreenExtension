{
  "manifest_version": 3,
  "name": "Sync Sketch Party",
  "version": "0.1.0",
  "description": "Iki kullanici arasinda canli cizim ve sohbet deneyimi sunan Chrome extension.",
  "permissions": [
    "identity",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://euzeprutflhfavzxuwfs.supabase.co/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_title": "Sync Sketch Party",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/overlay.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/dashboard/dashboard.html",
        "src/dashboard/dashboard.css",
        "src/dashboard/dashboard.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
