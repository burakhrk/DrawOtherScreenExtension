{
  "manifest_version": 3,
  "name": "Sketch Party",
  "version": "0.1.0",
  "description": "A Chrome extension for live drawing, playful effects, and chat between friends.",
  "permissions": [
    "identity",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://lpgdopfqvertiwcmyokh.supabase.co/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "public/icons/sketch-party-16.png",
    "32": "public/icons/sketch-party-32.png",
    "48": "public/icons/sketch-party-48.png",
    "128": "public/icons/sketch-party-128.png"
  },
  "action": {
    "default_title": "Sketch Party",
    "default_icon": {
      "16": "public/icons/sketch-party-16.png",
      "32": "public/icons/sketch-party-32.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/overlay.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/dashboard/dashboard.html",
        "src/dashboard/dashboard.css",
        "src/dashboard/dashboard.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
